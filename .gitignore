# Rust
/target/
**/*.rs.bk
# Cargo.lock is intentionally committed: pq-diary is a binary application
# (cli/), so locking dependency versions is required for reproducible
# builds and to prevent CI from drifting against upstream breakage
# (see ml-dsa/pkcs8 incident discovered after S10 merge).

# pq-diary: plaintext cache (NEVER commit)
entries/

# Editor
*.swp
*.swo
*~
.*.un~

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.iml

# Automation logs
logs/
